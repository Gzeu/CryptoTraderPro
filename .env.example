# ─────────────────────────────────────────────────────────────
# CryptoTraderPro — Environment Variables
# Copy this file to .env.local and fill in your values
# ─────────────────────────────────────────────────────────────

# ── CryptoPanic ──────────────────────────────────────────────
# Get a free key at https://cryptopanic.com/developers/api/
# Without a key the public feed is used (rate-limited).
CRYPTOPANIC_API_KEY=

# ── CoinGecko ────────────────────────────────────────────────
# Free tier works without a key; Pro key removes rate limits.
# https://www.coingecko.com/en/api
COINGECKO_API_KEY=

# ── MultiversX ───────────────────────────────────────────────
# Public API is used by default. No key required.
# Override if you run your own MX API gateway.
MULTIVERSX_API_URL=https://api.multiversx.com

# ── App ──────────────────────────────────────────────────────
NEXT_PUBLIC_APP_URL=http://localhost:3000

# ── Binance WebSocket ────────────────────────────────────────
# Binance WS is public — no API key needed.
# Override stream base if you use a proxy.
# NEXT_PUBLIC_BINANCE_WS_BASE=wss://stream.binance.com:9443
