# CryptoTraderPro — Environment Variables
# Copy this file to .env.local and fill in your values

# CoinGecko API Key (optional — free tier works without it, but rate-limited)
# Get yours at https://www.coingecko.com/en/api
COINGECKO_API_KEY=

# App URL (used for OG metadata)
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Feature flags
NEXT_PUBLIC_ENABLE_PORTFOLIO=true
NEXT_PUBLIC_ENABLE_ALERTS=false
