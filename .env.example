# =============================================================================
# CryptoTraderPro — Environment Variables Example
# Copy this file to .env.local and fill in your values
# =============================================================================

# --- Next.js ---
NEXT_PUBLIC_APP_NAME=CryptoTraderPro

# --- Binance WebSocket (no key needed, public stream) ---
# wss://stream.binance.com:9443/ws/<symbol>@ticker
# wss://stream.binance.com:9443/stream?streams=...
# No API key required for public market data streams.

# --- MultiversX Public API (no key needed) ---
# Base URL: https://api.multiversx.com
# No API key required for read-only public endpoints.

# --- CoinGecko Free Tier (no key needed) ---
# Base URL: https://api.coingecko.com/api/v3
# Rate limit: ~30 requests/min on free tier.
# Optional: add a CoinGecko Pro key for higher limits.
# NEXT_PUBLIC_COINGECKO_API_KEY=your_pro_api_key_here

# --- Optional: Analytics ---
# NEXT_PUBLIC_POSTHOG_KEY=
# NEXT_PUBLIC_POSTHOG_HOST=https://app.posthog.com
